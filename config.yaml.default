# NGA 举报通知监听配置
# 请把文件名后缀config.yaml.default修改为config.yaml才能正常使用

# NGA 登录 Cookie（从浏览器开发者工具获取）
# 填写完整的 Cookie 字符串，以分号分隔
cookie: ""

# Server酱 3 推送配置
serverchan:
  sendkey: ""

# 免打扰时段（可选，不设置或留空则全天推送）
# 支持多段，跨天时段如 "23:00-07:00"
dnd_hours:
  - "23:00-07:00"
  # - "12:00-13:30"
  
# 抓取间隔（分钟）
interval_minutes: 5
